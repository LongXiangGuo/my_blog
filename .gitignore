# =========================================================================
# VitePress & Node.js 核心构建产物（严禁提交，数量极多且每天都在变）
# =========================================================================
node_modules/
.cache/
.temp/

# VitePress 本地执行 npm run build 生成的纯静态 HTML/CSS/JS 生产产物
# 这些产物应该由公司 CI/CD 流水线自动生成并推送到 Pages 服务器，不应占用源码仓库空间
.vitepress/dist/

# =========================================================================
# 操作系统与主流 IDE 开发环境缓存（防止团队成员之间互相覆盖配置）
# =========================================================================
.DS_Store
Thumbs.db
.idea/
.vscode/
*.log
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp

# =========================================================================
# 本地特定的环境覆盖（如果有）
# =========================================================================
.env
.env.local
.env.*.local
